# --- Notifications ---
NTFY_TOPIC=                  # e.g. btc-accum-yourname ; blank disables ntfy
NTFY_SERVER=https://ntfy.sh # override for a self-hosted ntfy instance
TELEGRAM_BOT_TOKEN=          # optional alternative
TELEGRAM_CHAT_ID=

# --- Free data ---
FRED_API_KEY=                # free from fredaccount.stlouisfed.org ; macro layer skipped if blank

# --- Paid drop-ins (leave blank to run free) ---
GLASSNODE_API_KEY=           # turns on the on-chain valuation layer
CRYPTOQUANT_API_KEY=         # alternative on-chain provider
COINGLASS_API_KEY=           # turns on richer derivatives layer
SOSOVALUE_API_KEY=           # optional, for ETF flows

# --- Signal config ---
SYMBOL=BTCUSDT
DB_PATH=./btc.db
# category weights (renormalized over whatever is available)
W_ONCHAIN=0.35
W_PRICE=0.20
W_MACRO=0.20
W_SENTIMENT=0.10
W_DERIVS=0.15
# tier thresholds
TIER_WATCH=40
TIER_ACCUMULATE=60
TIER_DEEPVALUE=80
# acute-capitulation flash
FLASH_FNG_MAX=10
FLASH_DROP_PCT=10            # % over 24-48h
FLASH_DEBOUNCE_DAYS=3
# cycle context
ATH_DATE=2025-10-06
PEAK_TO_TROUGH_DAYS=370
