# ===== Notifications =====
# Email via Resend is the primary channel after the pivot.
RESEND_API_KEY=              # from resend.com ; email disabled while blank
EMAIL_FROM=onboarding@resend.dev   # sandbox FROM; change to you@yourdomain after verifying a domain
EMAIL_TO=                    # where alerts go, e.g. skobrosli@gmail.com (sandbox only reaches your verified address)

# Optional secondary push channels
NTFY_TOPIC=                  # e.g. btc-accum-yourname ; blank disables ntfy
NTFY_SERVER=https://ntfy.sh
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Free data =====
FRED_API_KEY=                # free from fredaccount.stlouisfed.org ; macro layer skipped if blank
ONCHAIN_FREE=true            # on-chain valuation via free bitcoin-data.com feed; set false to disable
OI_FLUSH_WINDOW_HOURS=24     # window for the free OKX-OI-derived long-term oi_flush

# ===== Paid drop-ins (optional upgrades over the free defaults) =====
GLASSNODE_API_KEY=           # on-chain valuation upgrade (7d-smoothed; free bitcoin-data.com is the default)
CRYPTOQUANT_API_KEY=         # not wired (placeholder)
COINGLASS_API_KEY=           # richer derivatives (real liquidations / OI-weighted funding)
SOSOVALUE_API_KEY=           # optional, for ETF flows

# ===== Market data =====
EXCHANGE=okx                 # okx (default) | kraken | binance (binance only from unrestricted regions)
SYMBOL=BTC-USDT              # OKX/Kraken spot symbol (Binance would be BTCUSDT)
DB_PATH=./btc.db

# ===== Long-term signal config =====
W_ONCHAIN=0.35
W_PRICE=0.20
W_MACRO=0.20
W_SENTIMENT=0.10
W_DERIVS=0.15
TIER_WATCH=40
TIER_ACCUMULATE=60
TIER_DEEPVALUE=80
FLASH_FNG_MAX=10
FLASH_DROP_PCT=10
FLASH_DEBOUNCE_DAYS=3
ATH_DATE=2025-10-06
PEAK_TO_TROUGH_DAYS=370

# ===== Short-term swing config =====
ST_TIMEFRAMES=4h,1d          # comma list of swing timeframes
ST_COOLDOWN_HOURS=12         # min hours between repeats of the same trigger+timeframe
ST_RSI_OVERSOLD=30
ST_RSI_OVERBOUGHT=70
ST_VOL_SPIKE_MULT=2.0        # volume > this x rolling avg = spike
ST_FUNDING_SPIKE=0.0005      # |8h funding| above this = spike
ST_OI_SURGE_PCT=10.0         # OI change over window above this % = surge
ST_BUY_THRESHOLD=30          # st_composite (-100..100) >= this => BUY
ST_STRONG_BUY_THRESHOLD=60
ST_SELL_THRESHOLD=-30        # st_composite <= this => SELL
ST_STRONG_SELL_THRESHOLD=-60

# ===== Dashboard read-only API =====
API_TOKEN=                   # openssl rand -hex 32 ; internal dashboard<->API secret
API_CORS_ORIGIN=             # only needed if the dashboard is served cross-origin

# ===== Watchdog (dead-man's-switch) =====
WATCHDOG_STALE_HOURS=3       # email if no successful collect/run within this many hours

# ===== Stock swing tracker (second asset; free-tier) =====
# Runs on an empty .env: prices fall back to the keyless (fragile) Yahoo endpoint,
# and the SEC insider + FINRA short-vol layers are keyless. Add a free FINNHUB key
# to light up the scored PEAD edge; add Alpaca/Tiingo for a robust price feed.
FINNHUB_API_KEY=             # free key (finnhub.io) -> earnings calendar + surprises (PEAD)
ALPACA_API_KEY=              # optional: robust daily bars (data.alpaca.markets, free tier)
ALPACA_SECRET_KEY=
TIINGO_API_KEY=              # optional: alternative price feed (fine for a fixed <=500 universe)
SEC_USER_AGENT=riverviewweb-signal stock tracker admin@riverviewweb.com  # SEC requires a descriptive UA
STOCK_INSIDER=true           # keyless SEC Form-4 insider-cluster context layer
STOCK_SHORTVOL=true          # keyless FINRA short-volume context layer
STOCK_CONGRESS=false         # keyless congressional-trade scrape (Phase 3 forward-test)
STOCK_TOP_N=15               # how many ranked setups to surface
STOCK_PEAD_LOOKBACK_DAYS=10  # a PEAD setup stays live this many trading days post-report
STOCK_PEAD_MIN_SURPRISE=3.0  # min |EPS surprise %| to treat earnings as a signal
STOCK_MIN_PRICE=5.0          # liquidity floor
STOCK_MIN_DOLLAR_VOL=5000000 # avg daily $ volume floor
STOCK_TIME_STOP_DAYS=12      # fallback hard time-exit (archetypes override: pead 12 / mom 20 / meanrev 5)
STOCK_COOLDOWN_DAYS=5        # min days between repeats of the same (ticker, archetype) alert
STOCK_ALLOW_SHORTS=false      # Phase 1 long-only; true enables negative-PEAD/short setups (Phase 2)
