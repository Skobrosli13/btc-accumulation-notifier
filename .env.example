# ===== Notifications =====
# Email via Resend is the primary channel after the pivot.
RESEND_API_KEY=              # from resend.com ; email disabled while blank
EMAIL_FROM=onboarding@resend.dev   # sandbox FROM; change to you@yourdomain after verifying a domain
EMAIL_TO=                    # where alerts go, e.g. skobrosli@gmail.com (sandbox only reaches your verified address)

# Optional secondary push channels
NTFY_TOPIC=                  # e.g. btc-accum-yourname ; blank disables ntfy
NTFY_SERVER=https://ntfy.sh
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Free data =====
FRED_API_KEY=                # free from fredaccount.stlouisfed.org ; macro layer skipped if blank

# ===== Paid drop-ins (leave blank to run free) =====
GLASSNODE_API_KEY=           # on-chain valuation layer (biggest long-term accuracy upgrade)
CRYPTOQUANT_API_KEY=
COINGLASS_API_KEY=           # richer derivatives (real liquidations / OI-weighted funding)
SOSOVALUE_API_KEY=           # optional, for ETF flows

# ===== Market data =====
EXCHANGE=okx                 # okx (default) | kraken | binance (binance only from unrestricted regions)
SYMBOL=BTC-USDT              # OKX/Kraken spot symbol (Binance would be BTCUSDT)
DB_PATH=./btc.db

# ===== Long-term signal config =====
W_ONCHAIN=0.35
W_PRICE=0.20
W_MACRO=0.20
W_SENTIMENT=0.10
W_DERIVS=0.15
TIER_WATCH=40
TIER_ACCUMULATE=60
TIER_DEEPVALUE=80
FLASH_FNG_MAX=10
FLASH_DROP_PCT=10
FLASH_DEBOUNCE_DAYS=3
ATH_DATE=2025-10-06
PEAK_TO_TROUGH_DAYS=370

# ===== Short-term swing config =====
ST_TIMEFRAMES=4h,1d          # comma list of swing timeframes
ST_COOLDOWN_HOURS=12         # min hours between repeats of the same trigger+timeframe
ST_RSI_OVERSOLD=30
ST_RSI_OVERBOUGHT=70
ST_VOL_SPIKE_MULT=2.0        # volume > this x rolling avg = spike
ST_FUNDING_SPIKE=0.0005      # |8h funding| above this = spike
ST_OI_SURGE_PCT=10.0         # OI change over window above this % = surge
ST_BUY_THRESHOLD=30          # st_composite (-100..100) >= this => BUY
ST_STRONG_BUY_THRESHOLD=60
ST_SELL_THRESHOLD=-30        # st_composite <= this => SELL
ST_STRONG_SELL_THRESHOLD=-60

# ===== Dashboard read-only API =====
API_TOKEN=                   # openssl rand -hex 32 ; internal dashboard<->API secret
API_CORS_ORIGIN=             # only needed if the dashboard is served cross-origin

# ===== Watchdog (dead-man's-switch) =====
WATCHDOG_STALE_HOURS=3       # email if no successful collect/run within this many hours
